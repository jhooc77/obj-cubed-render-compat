  "description": "Runtime shader bridge between obj-cubed resource packs and upstream Iris.",
  "authors": ["jhooc77"],
  "license": "LGPL-3.0-only",
  "environment": "client",
  "mixins": [
    "obj-cubed-iris-compat.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "${minecraft_dependency}",
